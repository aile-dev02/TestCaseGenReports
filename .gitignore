# ─────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────
node_modules/

# ─────────────────────────────────────────────
# TypeScript build output
# ─────────────────────────────────────────────
dist/
*.tsbuildinfo

# ─────────────────────────────────────────────
# Generated reports
# reports/latest/ は CI artifact として保存するため Git 管理外。
# 過去分をアーカイブしたい場合は reports/archive/ を手動コミットする。
# ─────────────────────────────────────────────
reports/latest/
reports/archive/

# ─────────────────────────────────────────────
# Evidence (screenshots / logs) — 容量が大きいため Git LFS 推奨
# runs/*/evidence/ を管理したい場合は LFS を設定してコメントアウト
# ─────────────────────────────────────────────
runs/*/evidence/

# ─────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.iml

# ─────────────────────────────────────────────
# Tool-local directories
# ─────────────────────────────────────────────
# VS Code Local History extension
.history/
# Claude Code local settings
.claude/

# ─────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────
*.log
npm-debug.log*

# ─────────────────────────────────────────────
# Environment / secrets
# ─────────────────────────────────────────────
.env
.env.*
!.env.example
